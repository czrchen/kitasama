---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <img class="brand-logo" src="/images/logo/kitasama-logo.png" alt="Kitasama" height="34" />
      </a>
      <p>Malaysia's leading keropok lekor maker since 1988 — traditional fish-cracker recipes, made fresh in Klang.</p>
      <div class="socials">
        <a href="https://facebook.com/keropokkitasama" aria-label="Facebook">Facebook</a>
        <a href="#" aria-label="Instagram">Instagram</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/products">Products</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Products</h4>
      <a href="/products">Mega Soft Lekor</a>
      <a href="/products">Lekor Chips</a>
      <a href="/products">Keropok Batang</a>
      <a href="/products">Dipping Sauce</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <p class="muted">27, Jalan Teruntum 20/KU8, Off Jalan Meru, 41050 Klang, Selangor</p>
      <a href="tel:+60333929668">603-3392 9668</a>
      <a href="mailto:kitasamafood@gmail.com">kitasamafood@gmail.com</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Kitasama Food Sdn Bhd · Klang, Selangor</span>
    <span>We sell Malaysia food culture</span>
  </div>
</footer>

<style>
  .footer { position: relative; background: var(--ink); color: #C9D6C8; margin-top: 110px; padding: 70px 0 30px; }
  .footer-inner { display: grid; grid-template-columns: 1.7fr 1fr 1fr 1.4fr; gap: 40px; }
  .brand { display: flex; align-items: center; margin-bottom: 18px; }
  .brand-logo { height: 34px; width: auto; filter: brightness(0) invert(1); opacity: .92; }
  .footer-brand p { color: #93A593; max-width: 320px; font-size: .95rem; line-height: 1.6; }

  .socials { display: flex; gap: 18px; margin-top: 22px; }
  .socials a { font-size: .88rem; font-weight: 500; color: #93A593; transition: color .2s ease; }
  .socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-display); font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 18px; color: #6F856F;
  }
  .footer-col a { display: block; color: #C9D6C8; padding: 6px 0; font-size: .95rem; transition: color .18s ease; }
  .footer-col a:hover { color: #fff; }
  .footer-col .muted { color: #93A593; margin-bottom: 14px; font-size: .95rem; line-height: 1.6; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 54px; padding-top: 26px;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #6F856F; font-size: .86rem;
  }

  @media (max-width: 860px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .footer-inner { grid-template-columns: 1fr; gap: 30px; } }
</style>
