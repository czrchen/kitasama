---
// Wavy section divider. side="top" curves the section's top edge,
// side="bottom" curves the bottom. Fill matches the adjacent (paper) colour.
const { side = "top" } = Astro.props;
---
<div class={`wave wave-${side === "top" ? "t" : "b"}`} aria-hidden="true">
  <svg viewBox="0 0 1440 56" preserveAspectRatio="none">
    <path d="M0,0 H1440 V20 C1180,52 940,2 720,24 C500,46 250,2 0,24 Z" />
  </svg>
</div>
