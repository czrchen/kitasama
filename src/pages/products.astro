---
import Layout from "../layouts/Layout.astro";

const categories = [
  {
    name: "Mega Soft Keropok Lekor",
    accent: "var(--red)",
    items: [
      { img: "/images/products/mega-soft-frozen.jpg", name: "Mega Soft Frozen", desc: "Soft fish stick, frozen 1kg — long shelf life." },
      { img: "/images/products/mega-soft-chill.jpg", name: "Mega Soft Chill", desc: "Soft fish stick, chilled 1kg — ready to fry." },
      { img: "/images/products/mega-soft-fresh.jpg", name: "Mega Soft Fresh", desc: "Made-fresh lekor, 50-stick pack." },
    ],
  },
  {
    name: "Crispy Lekor & Crackers",
    accent: "var(--gold)",
    items: [
      { img: "/images/products/lekor-chips.jpg", name: "Lekor Chips", desc: "Sliced lekor crisps — crunchy, chilled 1kg." },
      { img: "/images/products/keropok-batang.jpg", name: "Keropok Batang", desc: "Stick-form fish crackers, 10 pcs." },
      { img: "/images/products/lekor-panjang.jpg", name: "Keropok Lekor Panjang", desc: "Long-form fish crackers, 25 pcs." },
    ],
  },
  {
    name: "Dipping Sauce",
    accent: "var(--navy)",
    items: [
      { img: "/images/products/sos-pencicah.jpg", name: "Sos Pencicah Lekor", desc: "The chili dipping sauce made for lekor, 1kg." },
    ],
  },
];
---

<Layout path="/products" title="Products — Central Vista Snacks & Confectionery">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" data-reveal>Our products</span>
      <h1 class="page-title" data-split>Our keropok lekor range</h1>
      <p class="page-lead" data-reveal>
        Soft fish sticks, crispy lekor chips, crackers and dipping sauce — fresh, chilled or frozen.
        Wholesale, food-service and export supply welcome.
      </p>
    </div>
  </section>

  {categories.map((cat) => (
    <section class="cat" style={`--c:${cat.accent}`}>
      <div class="container">
        <header class="cat-head" data-reveal>
          <span class="cat-bar"></span>
          <h2>{cat.name}</h2>
          <span class="cat-count">{cat.items.length} products</span>
        </header>
        <div class="cat-grid" data-reveal-group>
          {cat.items.map((it) => (
            <article class="pcard" tabindex="0">
              <div class="pcard-flip">
                <div class="pcard-face pcard-front">
                  <div class="pcard-media"><img src={it.img} alt={it.name} loading="lazy" width="600" height="400" /></div>
                  <h3>{it.name}</h3>
                  <span class="flip-hint">Hover for details ↻</span>
                </div>
                <div class="pcard-face pcard-back">
                  <span class="back-cat">{cat.name}</span>
                  <h3>{it.name}</h3>
                  <p>{it.desc}</p>
                  <span class="flip-hint light">↩ flip back</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</Layout>

<style>
  .page-hero { padding: 64px 0 50px; }
  .page-title { font-size: clamp(2.6rem, 6vw, 4.2rem); margin: 18px 0 18px; letter-spacing: -0.04em; }
  .page-lead { font-size: 1.12rem; color: var(--ink-soft); max-width: 600px; line-height: 1.65; }

  .cat { padding: 50px 0 0; }
  .cat-head { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
  .cat-bar { width: 32px; height: 6px; border-radius: 6px; background: var(--c); }
  .cat-head h2 { font-size: clamp(1.5rem, 3.2vw, 2rem); letter-spacing: -0.03em; }
  .cat-count { margin-left: auto; font-size: .82rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-soft); }

  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 34px; }
  /* Flip card — front shows the product, back reveals the description */
  .pcard { perspective: 1300px; outline: none; cursor: pointer; }
  .pcard-flip {
    position: relative; width: 100%; height: 360px;
    transform-style: preserve-3d;
    transition: transform .7s cubic-bezier(.2,.8,.25,1);
  }
  .pcard:hover .pcard-flip,
  .pcard:focus-within .pcard-flip { transform: rotateY(180deg); }
  .pcard-face {
    position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border-radius: 26px; overflow: hidden; display: flex; flex-direction: column;
  }
  .pcard-front { background: var(--white, #fff); border: 1px solid var(--line); padding: 18px; box-shadow: var(--shadow-sm); }
  .pcard-front .pcard-media { flex: 1; min-height: 0; background: var(--cream); border-radius: 18px; overflow: hidden; }
  .pcard-front .pcard-media img { width: 100%; height: 100%; object-fit: contain; padding: 16px; }
  .pcard-ph { width: 100%; height: 100%; display: grid; place-items: center; text-align: center; padding: 18px;
    background: linear-gradient(135deg, var(--red), var(--navy)); }
  .pcard-ph span { color: #fff; font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; opacity: .95; }
  .pcard-front h3 { font-size: 1.05rem; letter-spacing: -0.02em; margin-top: 14px; }
  .flip-hint { font-size: .68rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-soft); margin-top: 6px; }
  .flip-hint.light { color: rgba(255,255,255,.7); margin-top: 14px; }
  .pcard-back {
    background: var(--navy); color: #fff; transform: rotateY(180deg);
    border-top: 4px solid var(--c); padding: 30px 26px; justify-content: center;
  }
  .back-cat { font-size: .7rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--c); margin-bottom: 12px; }
  .pcard-back h3 { color: #fff; font-size: 1.4rem; letter-spacing: -0.02em; margin: 0 0 12px; }
  .pcard-back p { color: rgba(255,255,255,.84); font-size: 1rem; line-height: 1.55; }
  @media (prefers-reduced-motion: reduce) { .pcard-flip { transition: none; } }

  .oem-box {
    display: flex; justify-content: space-between; align-items: center;
    gap: 36px; flex-wrap: wrap;
  }
  .oem-box h2 { color: #fff; font-size: clamp(1.8rem, 3.6vw, 2.5rem); margin-bottom: 12px; }
  .oem-box p { color: rgba(255,255,255,.8); max-width: 480px; }
  .oem-box .btn { flex-shrink: 0; }

  @media (max-width: 900px) { .cat-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) {
    .cat-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
    .oem-box { padding: 40px 30px; }
  }
</style>
