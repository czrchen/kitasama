---
import Layout from "../layouts/Layout.astro";

const address = "27, Jalan Teruntum 20/KU8, Off Jalan Teratai, Batu 5½, Off Jalan Meru, 41050 Klang, Selangor, Malaysia.";
const phones = ["603-3392 9668", "6014-626 2133"];
const email = "kitasamafood@gmail.com";

const mapDir = "https://www.google.com/maps/dir/?api=1&destination=" +
  encodeURIComponent("Kitasama Food Sdn Bhd, Jalan Meru, 41050 Klang, Selangor");
const mapEmbed = "https://www.openstreetmap.org/export/embed.html?bbox=101.40%2C3.00%2C101.48%2C3.08&layer=mapnik&marker=3.0440%2C101.4390";
---

<Layout path="/contact" title="Contact — Kitasama Food">
  <section class="contact-head">
    <div class="container" data-reveal>
      <span class="eyebrow">Contact us</span>
      <h1>Let's talk supply.</h1>
      <p class="contact-lead">
        Want to stock Kitasama, or supply your restaurant or market? Reach our Klang team below,
        or send a message and we'll get back to you. Open Mon–Sat, 7am–6pm.
      </p>
    </div>
  </section>

  <section class="companies">
    <div class="container company-grid" data-reveal-group>
      <article class="company-card" style="--accent:var(--red)">
        <div class="company-logo"><img src="/images/logo/kitasama-logo.png" alt="Kitasama" /></div>
        <h2>Kitasama Food Sdn Bhd</h2>
        <p class="company-reg">Keropok lekor manufacturer · since 1988</p>
        <ul class="company-info">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg>
            <span>{address}</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L20 13l1 4v2a1 1 0 0 1-1 1A16 16 0 0 1 4 4a1 1 0 0 1 1-1Z"/></svg>
            <span>{phones.map((p) => <a href={`tel:+6${p.replace(/[^0-9]/g, "")}`}>{p}</a>)}</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            <span><a href={`mailto:${email}`}>{email}</a></span>
          </li>
        </ul>
      </article>
    </div>
  </section>

  <section class="form-sec">
    <div class="container">
      <form class="form" data-reveal onsubmit="event.preventDefault(); this.querySelector('.form-msg').style.display='block';">
        <h2>Send a message</h2>
        <div class="row">
          <div class="field"><label for="name">Name</label><input id="name" type="text" placeholder="Your name" required /></div>
          <div class="field"><label for="company">Company</label><input id="company" type="text" placeholder="Optional" /></div>
        </div>
        <div class="field"><label for="email">Email</label><input id="email" type="email" placeholder="you@company.com" required /></div>
        <div class="field"><label for="msg">Message</label><textarea id="msg" rows="5" placeholder="Tell us a little about what you need…" required></textarea></div>
        <button type="submit" class="btn btn-primary">Send message
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
        <p class="form-msg">Thanks — your message is ready. We'll be in touch soon.</p>
      </form>
    </div>
  </section>

  <section class="map-sec" data-reveal>
    <div class="map-frame">
      <iframe title="Kitasama Food location" src={mapEmbed} loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
    <a class="map-cta btn btn-dark" href={mapDir} target="_blank" rel="noopener">Get directions
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </section>
</Layout>

<style>
  .contact-head { padding: 70px 0 10px; }
  .contact-head h1 { font-size: clamp(2.4rem, 5vw, 3.6rem); margin: 18px 0 16px; letter-spacing: -0.04em; }
  .contact-lead { font-size: 1.1rem; color: var(--ink-soft); line-height: 1.65; max-width: 640px; }

  .companies { padding: 44px 0 0; }
  .company-grid { display: grid; grid-template-columns: 1fr; gap: 26px; max-width: 640px; }
  .company-card {
    background: #fff; border: 1px solid var(--line); border-top: 3px solid var(--accent);
    border-radius: var(--r-lg); padding: 34px 32px;
  }
  .company-logo { height: 64px; margin-bottom: 18px; }
  .company-logo img { height: 100%; width: auto; object-fit: contain; }
  .company-card h2 { font-size: 1.3rem; letter-spacing: -0.02em; }
  .company-reg { color: var(--ink-soft); font-size: .9rem; font-weight: 600; margin: 4px 0 20px; }
  .company-info { display: grid; gap: 14px; }
  .company-info li { display: flex; gap: 13px; align-items: flex-start; font-size: .96rem; color: var(--ink-soft); line-height: 1.5; }
  .company-info svg { width: 20px; height: 20px; color: var(--accent); flex-shrink: 0; margin-top: 1px; }
  .company-info span { display: flex; flex-direction: column; }
  .company-info a { color: var(--ink); }
  .company-info a:hover { color: var(--accent); }

  .form-sec { padding: 70px 0 0; }
  .form { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 40px; max-width: 720px; margin: 0 auto; }
  .form h2 { font-size: 1.5rem; margin-bottom: 26px; }
  .field { margin-bottom: 18px; display: flex; flex-direction: column; }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  label { font-weight: 600; margin-bottom: 8px; font-size: .9rem; }
  input, textarea {
    font-family: var(--font-body); font-size: 1rem; color: var(--ink);
    padding: 13px 15px; border: 1px solid var(--line-strong); border-radius: 11px;
    background: var(--paper); transition: border-color .18s ease, background .18s ease;
  }
  input::placeholder, textarea::placeholder { color: #A2A4B8; }
  input:focus, textarea:focus { outline: none; border-color: var(--navy); background: #fff; }
  textarea { resize: vertical; }
  .form .btn { margin-top: 6px; }
  .form-msg { display: none; margin-top: 18px; padding: 14px 18px; border-radius: 11px;
    background: rgba(35,44,115,.07); color: var(--navy); font-weight: 600; font-size: .95rem; }

  .map-sec { position: relative; margin-top: 90px; }
  .map-frame { line-height: 0; }
  .map-frame iframe { width: 100%; height: 460px; border: 0; display: block; filter: saturate(1.02); }
  .map-cta { position: absolute; left: 50%; bottom: 28px; transform: translateX(-50%); box-shadow: var(--shadow-md); }

  @media (max-width: 820px) {
    .company-grid { grid-template-columns: 1fr; }
    .row { grid-template-columns: 1fr; }
    .map-frame iframe { height: 360px; }
  }
</style>
