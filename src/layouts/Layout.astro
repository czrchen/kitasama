---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Kitasama — Malaysia's Keropok Lekor Since 1988",
  description = "Kitasama Food makes authentic Malaysian keropok lekor — soft fish sticks, lekor chips and crackers — fresh, chilled and frozen. Halal & MeSTI certified, made in Klang.",
  path = "/",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo/kitasama-logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav path={path} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function revealAll() {
        gsap.set("[data-reveal]", { opacity: 1, y: 0 });
        gsap.utils.toArray<HTMLElement>("[data-reveal-group]").forEach((g) =>
          gsap.set(g.children, { opacity: 1, y: 0 }));
        document.querySelectorAll("[data-timeline] > *").forEach((el) => el.classList.add("tl-in"));
      }

      function initMotion() {
        if (reduce) { revealAll(); return; }

        // Hero entrance — only on pages with a hero (avoids "target not found" warnings).
        // Use fromTo (explicit end state) so elements always settle visible — gsap.from can
        // "stick" at the from-state and leave the hero invisible.
        if (document.querySelector("[data-hero-stagger]")) {
          gsap.timeline({ defaults: { ease: "power3.out" } })
            .fromTo("[data-hero-stagger] > *",
              { y: 28, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.85, stagger: 0.09 })
            .fromTo("[data-hero-art] > *",
              { scale: 0.9, opacity: 0 },
              { scale: 1, opacity: 1, duration: 0.9, stagger: 0.12, ease: "back.out(1.5)" }, "-=0.55");
        }

        // Scroll reveals
        gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((el) => {
          gsap.to(el, {
            y: 0, opacity: 1, duration: 0.8, ease: "power3.out",
            scrollTrigger: { trigger: el, start: "top 92%", once: true },
          });
        });

        // Staggered groups — pop in with a gentle overshoot
        gsap.utils.toArray<HTMLElement>("[data-reveal-group]").forEach((group) => {
          const kids = group.children;
          gsap.set(kids, { y: 34, opacity: 0, scale: 0.95 });
          ScrollTrigger.create({
            trigger: group,
            start: "top 90%",
            once: true,
            onEnter: () => {
              gsap.to(kids, {
                y: 0, opacity: 1, scale: 1, duration: 0.7, stagger: 0.09, ease: "back.out(1.3)",
              });
            },
          });
        });

        // Gentle continuous float (e.g. certification logos)
        gsap.utils.toArray<HTMLElement>("[data-float]").forEach((el, i) => {
          gsap.to(el, {
            y: -9,
            duration: 2 + (i % 4) * 0.25,
            ease: "sine.inOut",
            repeat: -1,
            yoyo: true,
            delay: i * 0.18,
          });
        });

        // Parallax — elements drift as they scroll through the viewport
        gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
          const amt = parseFloat(el.getAttribute("data-parallax") || "24");
          gsap.fromTo(el, { y: amt }, {
            y: -amt, ease: "none",
            scrollTrigger: { trigger: el, start: "top bottom", end: "bottom top", scrub: 0.5 },
          });
        });

        // Count-up stats
        gsap.utils.toArray<HTMLElement>("[data-count]").forEach((el) => {
          const target = Number(el.dataset.count || "0");
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target, duration: 1.8, ease: "power2.out",
            scrollTrigger: { trigger: el, start: "top 92%", once: true },
            onUpdate: () => { el.textContent = Math.round(obj.val).toString(); },
          });
        });

        // Reversible timeline reveal — appears on scroll down, hides on scroll up
        gsap.utils.toArray<HTMLElement>("[data-timeline] > *").forEach((el) => {
          ScrollTrigger.create({
            trigger: el, start: "top 86%",
            onEnter: () => el.classList.add("tl-in"),
            onLeaveBack: () => el.classList.remove("tl-in"),
          });
        });

        // Firecracker / confetti burst from both screen corners
        function fireConfetti() {
          const cs = getComputedStyle(document.documentElement);
          const pick = (n: string) => cs.getPropertyValue(n).trim();
          const colors = [pick("--red"), pick("--gold"), pick("--navy"), "#ffffff", "#FF5C8A", "#19C3FF", "#FFD200", "#22C55E"].filter(Boolean);
          const overlay = document.createElement("div");
          overlay.style.cssText = "position:fixed;inset:0;overflow:hidden;pointer-events:none;z-index:9999;";
          document.body.appendChild(overlay);
          const W = window.innerWidth, H = window.innerHeight;
          ([[0, 1], [W, -1]] as [number, number][]).forEach(([x0, dir]) => {
            for (let i = 0; i < 50; i++) {
              const p = document.createElement("span");
              const sz = 7 + Math.random() * 9;
              p.style.cssText = "position:absolute;left:" + x0 + "px;top:" + H + "px;width:" + sz + "px;height:" + (sz * 0.55) + "px;background:" + colors[i % colors.length] + ";border-radius:2px;opacity:0;will-change:transform;";
              overlay.appendChild(p);
              gsap.timeline()
                .set(p, { opacity: 1, scale: 0.4 })
                .to(p, { x: dir * (W * 0.25 + Math.random() * W * 0.55), y: -(H * 0.45 + Math.random() * H * 0.5), rotation: Math.random() * 720 - 360, scale: 1, duration: 0.5 + Math.random() * 0.35, ease: "power3.out" })
                .to(p, { y: "+=" + (H * 0.7 + Math.random() * H * 0.3), rotation: "+=" + (Math.random() * 360), opacity: 0, duration: 1.0 + Math.random() * 0.8, ease: "power1.in" }, "-=0.05");
            }
          });
          gsap.delayedCall(3.6, () => overlay.remove());
        }
        const fcHost = document.querySelector<HTMLElement>("[data-firecracker]");
        if (fcHost) {
          if (fcHost.getBoundingClientRect().top < window.innerHeight * 0.85) {
            gsap.delayedCall(0.5, fireConfetti);
          } else {
            ScrollTrigger.create({ trigger: fcHost, start: "top 75%", once: true, onEnter: fireConfetti });
          }
        }

        // Recalculate trigger positions once everything (incl. fonts/images) settles
        ScrollTrigger.refresh();
        window.addEventListener("load", () => ScrollTrigger.refresh());
        setTimeout(() => ScrollTrigger.refresh(), 1200);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initMotion);
      } else {
        initMotion();
      }
    </script>
  </body>
</html>
